{
  "realm": "social-network",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrateur de l'application" },
      { "name": "user", "description": "Utilisateur standard" }
    ]
  },
  "clients": [
    {
      "clientId": "social-net-front",
      "name": "Frontend Vue (public)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    },
    {
      "clientId": "social-net-back",
      "name": "Backend Node (confidential)",
      "enabled": true,
      "publicClient": false,
      "secret": "backend-client-secret-12345",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false
    }
  ],
  "users": [
    {
      "username": "service-account-social-net-back",
      "enabled": true,
      "serviceAccountClientId": "social-net-back",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    },
    {
      "username": "appadmin",
      "enabled": true,
      "emailVerified": true,
      "email": "appadmin@mail.com",
      "firstName": "App",
      "lastName": "Admin",
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "appadmin", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ]
}